{
  "name": "neomono",
  "displayName": "Neomono",
  "description": "%extension.description%",
  "version": "0.0.8",
  "publisher": "Monosen",
  "license": "MIT",
  "author": {
    "name": "Monosen",
    "url": "https://github.com/Monosen"
  },
  "homepage": "https://github.com/Monosen/Neomono#readme",
  "bugs": {
    "url": "https://github.com/Monosen/Neomono/issues"
  },
  "keywords": [
    "theme",
    "dark",
    "neon",
    "cyberpunk",
    "dracula",
    "vibrant",
    "color-theme",
    "neomono",
    "glow"
  ],
  "qna": "marketplace",
  "icon": "assets/neomono-icon.jpg",
  "galleryBanner": {
    "color": "#bd93f9",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Monosen/Neomono.git"
  },
  "engines": {
    "vscode": "^1.80.0",
    "node": ">=18"
  },
  "categories": [
    "Themes"
  ],
  "main": "./src/extension.js",
  "l10n": "./l10n",
  "activationEvents": [
    "onCommand:neomono.enableNeonDreams",
    "onCommand:neomono.disableNeonDreams",
    "onCommand:neomono.toggleNeonDreams"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Neomono",
        "uiTheme": "vs-dark",
        "path": "./themes/Neomono-color-theme.json"
      }
    ],
    "commands": [
      {
        "command": "neomono.enableNeonDreams",
        "title": "%command.enableNeonDreams.title%",
        "category": "Neomono"
      },
      {
        "command": "neomono.disableNeonDreams",
        "title": "%command.disableNeonDreams.title%",
        "category": "Neomono"
      },
      {
        "command": "neomono.toggleNeonDreams",
        "title": "%command.toggleNeonDreams.title%",
        "category": "Neomono"
      }
    ],
    "configuration": {
      "title": "Neomono",
      "properties": {
        "neomono.neonDreams.autoReload": {
          "type": "boolean",
          "default": true,
          "description": "%config.autoReload.description%"
        },
        "neomono.neonDreams.showNotifications": {
          "type": "boolean",
          "default": true,
          "description": "%config.showNotifications.description%"
        }
      }
    }
  },
  "scripts": {
    "validate:theme": "node scripts/validate-theme.js",
    "lint": "eslint src scripts",
    "badges:vscode": "node scripts/switch-badges.js vscode",
    "badges:ovsx": "node scripts/switch-badges.js ovsx",
    "vscode:prepublish": "npm run validate:theme",
    "package": "vsce package",
    "publish:vscode": "vsce publish",
    "publish:ovsx": "ovsx publish"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@vscode/vsce": "^3.2.1",
    "eslint": "^9.17.0",
    "ovsx": "^0.10.1"
  }
}
